// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())

  email String @unique
  password  String
}

model Repo {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())

  ghId        String   @unique
  name        String
  owner       String
  type        RepoType
  homepage    String?
  htmlUrl     String
  licenseName String?
  licenseUrl  String?
  thumbnail   String
  description String?
  created_at  String
  stacks      String[]
}

model RepoName {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())

  ghId  String   @unique
  name  String
  owner String
  type  RepoType
}

enum RepoType {
  User
  Organization
}
